# Email settings for send_email.py — copy this file to ".env" and fill in real values.
# IMPORTANT: For Gmail you must use an "App Password" (16 chars), NOT your normal
# account password. Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled).

EMAIL_FROM=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_TO=destination_address@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
